#!/bin/bash
# Chat server execution script used by the API server
# Expects: REPO_URL, PRIMARY_BRANCH, MODEL, CHAT_ID, PROJECT_NAME, SSH_KEY, SSH_CONFIG

# NOTE: This script does NOT use the standard timestamped logging boilerplate
# because it must output a raw PORT number on stdout for the API server to consume.

set -e

# Locate podman dynamically
PODMAN=$(which podman 2>/dev/null || true)
if [ -z "$PODMAN" ]; then
  for p in /opt/podman/bin/podman /usr/local/bin/podman /usr/bin/podman; do
    if [ -x "$p" ]; then
      PODMAN="$p"
      break
    fi
  done
fi

if [ -z "$PODMAN" ]; then
  echo "Error: podman not found"
  exit 127
fi

# Validate required inputs
if [ -z "$CHAT_ID" ]; then echo "Error: CHAT_ID is required"; exit 1; fi
if [ -z "$REPO_URL" ]; then echo "Error: REPO_URL is required"; exit 1; fi
if [ -z "$PROJECT_NAME" ]; then echo "Error: PROJECT_NAME is required"; exit 1; fi

# Check if container already exists
CONTAINER_NAME="overdrive-chat-${PROJECT_NAME}-${CHAT_ID}"
EXISTING_ID=$($PODMAN ps -q -f name=$CONTAINER_NAME)
if [ -n "$EXISTING_ID" ]; then
    # Return existing port
    # Output format of podman port: 3000/tcp -> 0.0.0.0:38475
    PORT_MAPPING=$($PODMAN port $CONTAINER_NAME 3000)
    PORT=$(echo "$PORT_MAPPING" | head -n 1 | awk -F: '{print $NF}')
    echo "$PORT"
    exit 0
fi

# Create build context
BUILD_CTX=$(mktemp -d)
trap 'rm -rf "$BUILD_CTX"' EXIT

# Copy common files
if [ -d ".opencode" ]; then
    cp -r .opencode "$BUILD_CTX/"
else
    mkdir "$BUILD_CTX/.opencode" # Ensure directory exists for COPY
fi

cp -r imgs "$BUILD_CTX/"

# Handle authentication
if [ -n "$AUTH_JSON" ]; then
    AUTH_JSON_CONTENT="$AUTH_JSON"
elif [ -f auth.json ]; then
    AUTH_JSON_CONTENT=$(cat auth.json)
else
    AUTH_JSON_CONTENT="{}"
fi

# Handle SSH Key
if [ -n "$SSH_KEY" ] && [ -f "$SSH_KEY" ]; then
    cp "$SSH_KEY" "$BUILD_CTX/ssh.key"
else
    # For chat, SSH key might be optional if repo is public, but let's be safe
    touch "$BUILD_CTX/ssh.key"
fi

# Handle SSH Config
if [ -n "$SSH_CONFIG" ] && [ -f "$SSH_CONFIG" ]; then
    cp "$SSH_CONFIG" "$BUILD_CTX/ssh_config"
else
    # Create empty config if not provided
    touch "$BUILD_CTX/ssh_config"
fi

# Build Base Image
# echo "Ensuring overdrive-base image..."
if ! "$PODMAN" image exists overdrive-base; then
    "$PODMAN" build -q -t overdrive-base imgs/base > /dev/null
fi

# Determine Project Base Image
BASE_IMAGE="overdrive-base"
if [ "$HARNESS_PROVIDER" = "claude-code" ]; then
    # In a real implementation, we'd have a claude-base image
    # For now, we'll just use overdrive-base and maybe it has claude installed
    BASE_IMAGE="overdrive-base"
fi

PROJECT_DOCKERFILE="projects/$PROJECT_NAME/Dockerfile"

if [ -f "$PROJECT_DOCKERFILE" ]; then
    PROJECT_BASE_TAG="overdrive-base-$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]//g')"
    # echo "Building custom environment for $PROJECT_NAME ($PROJECT_BASE_TAG)..."
    if ! "$PODMAN" image exists "$PROJECT_BASE_TAG"; then
        "$PODMAN" build -q -t "$PROJECT_BASE_TAG" -f "$PROJECT_DOCKERFILE" "projects/$PROJECT_NAME" > /dev/null
    fi
    BASE_IMAGE="$PROJECT_BASE_TAG"
fi

# Build image
TAG="chat-server-$PROJECT_NAME"
# Sanitize tag
TAG=$(echo "$TAG" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]//g')

# Determine entrypoint file
ENTRYPOINT_FILE="imgs/chat-server-entrypoint.sh"
if [ "$HARNESS_PROVIDER" = "claude-code" ]; then
    # We would need a different entrypoint for Claude Code
    # For now, we'll stick with the default or assume it handles both
    ENTRYPOINT_FILE="imgs/chat-server-entrypoint.sh"
fi

# Generate dynamic Dockerfile
cat <<EOF > "$BUILD_CTX/Dockerfile"
FROM $BASE_IMAGE

WORKDIR /overdrive

COPY .opencode /root/.opencode/
COPY ssh.key /ssh.key
RUN chmod 600 /ssh.key

# Copy and setup SSH config
RUN mkdir -p /root/.ssh && chmod 700 /root/.ssh
COPY ssh_config /root/.ssh/config
RUN chmod 600 /root/.ssh/config

# Copy and setup entrypoint
COPY $ENTRYPOINT_FILE /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
EOF

# Build Final Worker
# Use --cache-from to leverage cached layers if image already exists
CACHE_FLAG=""
if "$PODMAN" image exists "$TAG"; then
    CACHE_FLAG="--cache-from $TAG"
fi
"$PODMAN" build -q -f "$BUILD_CTX/Dockerfile" -t "$TAG" $CACHE_FLAG "$BUILD_CTX" > /dev/null

# Setup log directory
LOG_DIR="$(pwd)/projects/$PROJECT_NAME/logs/$CHAT_ID"
mkdir -p "$LOG_DIR"

# Setup data directory for persistence
DATA_DIR="$(pwd)/projects/$PROJECT_NAME/chats_data/$CHAT_ID"
mkdir -p "$DATA_DIR"
# Place auth.json specifically at its persistent location
echo "$AUTH_JSON_CONTENT" > "$DATA_DIR/auth.json"

# Run container
# Map container port 3000 to a random host port (-P or -p 0:3000)
# We use -P (publish-all) and check port mapping, or -p 0:3000
CID=$("$PODMAN" run -d --rm \
  --name "$CONTAINER_NAME" \
  --label "project=$PROJECT_NAME" \
  --label "chat_id=$CHAT_ID" \
  --label "type=chat" \
  --pull=never \
  -p 3000 \
  -v "$LOG_DIR:/log" \
  -v "$DATA_DIR:/root/.local/share/opencode" \
  -e AUTH_JSON="$AUTH_JSON_CONTENT" \
  -e REPO_URL="$REPO_URL" \
  -e PRIMARY_BRANCH="${PRIMARY_BRANCH:-main}" \
  -e MODEL="${MODEL:-google/gemini-3-flash-preview}" \
  -e LLM_PROVIDER="$LLM_PROVIDER" \
  -e HARNESS_PROVIDER="$HARNESS_PROVIDER" \
  -e OPENCODE_SESSION_ID="$OPENCODE_SESSION_ID" \
  "$TAG")


# Wait for port mapping to be available
# Instead of fixed sleep, poll for the port
MAX_RETRIES=20
RETRY_COUNT=0
PORT=""
while [ -z "$PORT" ] && [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
    PORT_MAPPING=$("$PODMAN" port "$CONTAINER_NAME" 3000 2>/dev/null || true)
    if [ -n "$PORT_MAPPING" ]; then
    PORT=$(echo "$PORT_MAPPING" | head -n 1 | awk -F: '{print $NF}')
    fi
    if [ -z "$PORT" ]; then
        sleep 0.1
        RETRY_COUNT=$((RETRY_COUNT+1))
    fi
done

if [ -z "$PORT" ]; then
    echo "Error: Failed to get port mapping for container $CONTAINER_NAME" >&2
    exit 1
fi

echo "$PORT"
