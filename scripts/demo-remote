#!/bin/bash
# Setup logging with timestamps
exec > >(while IFS= read -r line || [ -n "$line" ]; do
    if [[ ! "$line" =~ ^\[[0-9]{4}-[0-9]{2}-[0-9]{2} ]]; then
        printf "[$(date +'%Y-%m-%d %H:%M:%S')] %s\n" "$line"
    else
        printf "%s\n" "$line"
    fi
done) 2>&1

set -e

# Configuration
export DOCKERFILE="worker"
export REPO_URL="ssh://git@192.168.0.12:2212/volume1/git/infinimaze.git"
export BRANCH_PARENT="main"
export COMMIT_MSG="Remote test build"
export PROMPT="hi, how are you?"
export MODEL="google/gemini-3-flash-preview"
export SSH_KEY_PATH="$(pwd)/ssh.key"
export REMOTE_HOST="overdrive-worker-01"

echo "Running remote worker demo on $REMOTE_HOST..."
./scripts/deploy
