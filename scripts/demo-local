#!/bin/bash
# Setup logging with timestamps
exec > >(while IFS= read -r line || [ -n "$line" ]; do
    if [[ ! "$line" =~ ^\[[0-9]{4}-[0-9]{2}-[0-9]{2} ]]; then
        printf "[$(date +'%Y-%m-%d %H:%M:%S')] %s\n" "$line"
    else
        printf "%s\n" "$line"
    fi
done) 2>&1

set -e

# Configuration
DOCKERFILE="worker"
REPO_URL="ssh://git@192.168.0.12:2212/volume1/git/infinimaze.git"
BRANCH_PARENT="main"
COMMIT_MSG="Init build_docs"
PROMPT="hi, how are you?"
MODEL="google/gemini-3-flash-preview"
SSH_KEY_PATH="$(pwd)/ssh.key"

echo "Running local worker demo..."

# Handle SSH Key for build context
TARGET_KEY="./ssh.key"
if [[ ! "$SSH_KEY_PATH" -ef "$TARGET_KEY" ]]; then
  echo "Copying SSH key to build context..."
  cp "$SSH_KEY_PATH" "$TARGET_KEY"
  trap 'rm -f "$TARGET_KEY"' EXIT
fi

# Generate Job ID and Log Directory
to_base62() {
  local chars="0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
  local n=$1
  local res=""
  while [ "$n" -gt 0 ]; do
    res="${chars:$((n % 62)):1}$res"
    n=$((n / 62))
  done
  echo "$res"
}
JOB_ID=$(to_base62 $(date +%s%N))
LOG_DIR="$(pwd)/logs/$JOB_ID"
mkdir -p "$LOG_DIR"
echo "Logs will be available in: $LOG_DIR"

echo "Building Podman image from imgs/$DOCKERFILE..."
podman build -f "imgs/$DOCKERFILE" -t "$DOCKERFILE" .

# Run the container and capture exit code
set +e
podman run --rm \
  -v "$LOG_DIR:/log" \
  -e REPO_URL="$REPO_URL" \
  -e WORKER_BRANCH="$BRANCH_PARENT" \
  -e COMMIT_MSG="$COMMIT_MSG" \
  -e PROMPT="$PROMPT" \
  -e MODEL="$MODEL" \
  "$DOCKERFILE"
WORKER_EXIT_CODE=$?
set -e

if [ $WORKER_EXIT_CODE -eq 2 ]; then
  echo ">>> Result: NO-OP (No changes to commit)"
elif [ $WORKER_EXIT_CODE -ne 0 ]; then
  echo ">>> Result: CRASH (Worker failed with exit code $WORKER_EXIT_CODE)"
  exit $WORKER_EXIT_CODE
else
  echo ">>> Result: DONE (Changes pushed)"
fi
